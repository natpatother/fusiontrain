# Azure PostgreSQL Flexible Server
DATABASE_URL=postgresql://myuser:mypassword@myserver.postgres.database.azure.com:5432/postgres?sslmode=require

# Which LLM backend to use: azure_openai | foundry
LLM_PROVIDER=azure_openai

# Embedding vector size — MUST match the model and the DB column:
#   text-embedding-3-large -> 3072
#   text-embedding-3-small -> 1536
EMBEDDING_DIM=3072

# ---------- Option A: Azure OpenAI Service ----------
AZURE_OPENAI_ENDPOINT=https://my-openai-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2024-10-21
# Deployment names (as created in Azure OpenAI Studio)
EMBEDDING_DEPLOYMENT=text-embedding-3-large
CHAT_DEPLOYMENT=gpt-4o-mini

# ---------- Option B: Azure AI Foundry ----------
# Model inference endpoint, e.g. https://<resource>.services.ai.azure.com/models
FOUNDRY_ENDPOINT=https://my-foundry-resource.services.ai.azure.com/models
FOUNDRY_API_KEY=your-foundry-key
FOUNDRY_API_VERSION=2024-05-01-preview
# Model names as deployed in your Foundry project
FOUNDRY_EMBEDDING_MODEL=text-embedding-3-large
FOUNDRY_CHAT_MODEL=gpt-4o-mini

# RAG tuning
TOP_K=4

# CORS (comma-separated origins; * for any)
ALLOWED_ORIGINS=*
